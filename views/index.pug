extends layout.pug

block navicon
    a(class="navbar-brand" href="/dashboard") Weathertop

block navitemtop
    li(class="nav-item active")
        a(class="nav-link" href="/signup") Registrieren

block content
    div(class="container d-flex flex-row")
        div(class="container")
            img(src='icons/weather.jpg' class="float-left"  style="max-width:100%")
        div(class="container")
            form(action="/" method="post")
                div(class="form-group")
                    label(for="email") Email
                    input(type="email" class="form-control" name="email" id="email" placeholder="Email eingeben")
                div(class="form-group")
                    label(for="passwort") Passwort
                    input(type="password" class="form-control" name="passwort" id="passwort" placeholder="Passwort eingeben")
                iv(class="form-group")
                    button(type="submit" class="btn btn-primary") Einloggen
        
    if login_error
        div(class="alert alert-danger" role="alert") #{login_error}